# Path to the engine's video2pano.py script (REQUIRED)
ENGINE_SCRIPT=../engine/video2pano.py

# Python binary to invoke the engine with
ENGINE_PYTHON=python3

# Engine project root (passed as --project-root to video2pano.py)
# If not set, the engine defaults to its own script directory
ENGINE_ROOT=../engine

# Port for the Flask server
PORT=8080

# Directory for job artifacts (uploaded videos, output panoramas)
JOBS_DIR=./jobs
