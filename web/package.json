{
  "name": "openpano-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:next\"",
    "dev:next": "next dev --port 3000",
    "dev:api": "PYTHON=${PYTHON:-python3} && $PYTHON server.py",
    "build": "next build",
    "start": "concurrently \"npm run dev:api\" \"next start\"",
    "lint": "eslint"
  },
  "dependencies": {
    "concurrently": "^9.2.1",
    "next": "16.2.1",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
